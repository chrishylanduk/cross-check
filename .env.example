# Backend environment variables — copy to .env and fill in your values.
# .env is gitignored; this file is committed as a reference.
# See frontend/.env.example for frontend variables.
#
# Lines marked REQUIRED must be changed before the app will work.
# Lines marked OPTIONAL can be left as-is or omitted entirely.

# OPTIONAL — development works fine; set to "production" when deploying
ENVIRONMENT=development

# OPTIONAL — matches the default frontend dev port; update for production
CORS_ORIGINS=http://localhost:3000

# === Authentication ===
# Choose exactly one option. Option A works locally with no extra setup.

# --- Option A: Prototype password ---
# REQUIRED — change to any password longer than 6 characters
PROTOTYPE_PASSWORD=change-me

# --- Option B: Clerk email auth (comment out PROTOTYPE_PASSWORD above first) ---
# REQUIRED if using Clerk — get these from the Clerk dashboard
# CLERK_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# OPTIONAL — restrict to specific domains; leave unset to allow all Clerk users
# ALLOWED_EMAIL_DOMAINS=example.org,@example.com

# === AI Analysis ===

# OPTIONAL — default model; change prefix to swap provider:
#   openai:gpt-4.1-mini          (default)
#   anthropic:claude-3-5-haiku-latest
#   google-gla:gemini-2.0-flash
# See https://ai.pydantic.dev/models/ for all supported models
ANALYSIS_MODEL=openai:gpt-4.1-mini

# REQUIRED — API key for whichever provider ANALYSIS_MODEL uses
OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# OPTIONAL — custom OpenAI-compatible base URL (Gemini, Ollama, vLLM, etc.)
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# === Demo files (optional) ===
# All three required to enable the demo button on the upload page.
# B2_KEY_ID=
# B2_APPLICATION_KEY=
# B2_BUCKET_NAME=

# === Observability (optional) ===
# PHOENIX_ENDPOINT=http://localhost:6006
