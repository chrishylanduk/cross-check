# Environment Variables Template
# Copy this file to .env and fill in your actual values
#
# The .env file is ignored by git - you can store secrets there safely.

# === Backend Configuration ===

# Environment: development or production
# Controls API docs visibility and security headers
ENVIRONMENT=development

# Comma-separated list of allowed CORS origins
# For production, set to your frontend URL(s)
# Example: https://your-app.railway.app,https://custom-domain.com
CORS_ORIGINS=http://localhost:3000

# Port for backend server (default: 8000)
# Railway and other platforms set this automatically
PORT=8000

# === Frontend Configuration ===

# API endpoint URL
# For local development: http://localhost:8000
# For production: set to your backend service URL
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# === Authentication ===
# You must configure exactly one of the two options below.
# See README.md for full setup instructions.

# --- Option A: Prototype password (simple, default) ---
# A shared password that gates access to the app.
# Must be more than 6 characters.
# Remove these lines entirely when using Clerk (Option B).
PROTOTYPE_PASSWORD=your-secure-password-here
# DISABLE_PROTOTYPE_PASSWORD=true   # set instead of PROTOTYPE_PASSWORD to disable auth entirely

# --- Option B: Clerk email auth (recommended for shared deployments) ---
# Replaces the prototype password with email verification codes.
# Cannot be set at the same time as PROTOTYPE_PASSWORD.
# See README.md for required Clerk dashboard configuration steps.
#
# CLERK_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
#
# Comma-separated list of allowed email domains.
# A bare domain also matches all subdomains (e.g. "example.org" allows sub.example.org).
# Prefix with @ for exact-domain match only (e.g. "@example.com" does not allow sub.example.com).
# Leave unset to allow all verified Clerk users.
# ALLOWED_EMAIL_DOMAINS=example.org,@example.com

# === AI Analysis Configuration ===

# Model string passed directly to PydanticAI — change the prefix to swap provider:
#   openai:gpt-4.1-mini          (default)
#   anthropic:claude-3-5-haiku-latest
#   google-gla:gemini-2.0-flash
#   bedrock:us.amazon.nova-lite-v1:0
# See https://ai.pydantic.dev/models/ for all supported models
ANALYSIS_MODEL=openai:gpt-4.1-mini

# API key for your chosen provider (set the one that matches ANALYSIS_MODEL)
OPENAI_API_KEY=your-openai-key-here
# ANTHROPIC_API_KEY=your-anthropic-key-here
# GOOGLE_API_KEY=your-google-key-here
# AWS credentials are read from the standard AWS credential chain for Bedrock

# Provider name shown to users on the data usage notice (default: OpenAI)
# AI_PROVIDER_NAME=Anthropic

# URL to the provider's privacy policy shown on the data usage notice
# Leave unset or empty if using a local model with no external privacy policy
# AI_PRIVACY_POLICY_URL=https://www.anthropic.com/privacy

# === Observability (optional) ===

# Arize Phoenix endpoint for AI tracing (run: uv run phoenix serve)
# Leave unset to disable tracing
# PHOENIX_ENDPOINT=http://localhost:6006
