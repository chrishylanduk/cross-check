# Frontend environment variables — copy to .env and fill in your values.
# .env is gitignored; this file is committed as a reference.
# See .env.example in the project root for backend variables.
#
# Lines marked REQUIRED must be changed before the app will work.
# Lines marked OPTIONAL can be left as-is or omitted entirely.

# OPTIONAL — matches the default backend dev port; update for production
NEXT_PUBLIC_API_BASE=http://localhost:8000

# OPTIONAL — suppresses Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# === Authentication ===
# Option A (prototype password) needs no frontend vars.
# Option B (Clerk) requires the two vars below.

# REQUIRED if using Clerk — get these from the Clerk dashboard
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
# CLERK_SECRET_KEY=sk_live_...
# OPTIONAL — must match ALLOWED_EMAIL_DOMAINS on the backend if set
# ALLOWED_EMAIL_DOMAINS=example.org,@example.com

# === Data usage notice ===
# OPTIONAL — shown to users before content is sent to an AI provider
# AI_PROVIDER_NAME=Anthropic
# AI_PRIVACY_POLICY_URL=https://www.anthropic.com/privacy
